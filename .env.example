# Copy this file to ".env" and paste your keys after the = signs.
# This file is read by generate-data.js. Never commit your real .env.

# --- Required: places + ratings + the ranking ------------------------------
# Get a key: https://console.cloud.google.com  (enable "Places API (New)")
GOOGLE_PLACES_API_KEY=PASTE_YOUR_KEY_HERE

# --- Optional: the "read ALL reviews" hype-vs-love numbers ------------------
# Without these, mentions/approval are blank ("not yet rated") unless you add
# a manual entry in verified-dishes.js. With a provider key, the generator
# pulls every review per spot and computes approval = % rated 4★+ over all of
# the dish's mentions — no sampling.
#
# Provider: "serpapi" (default), "outscraper", or "none" to disable.
REVIEWS_PROVIDER=serpapi
# SerpAPI key (https://serpapi.com) — used when REVIEWS_PROVIDER=serpapi.
SERPAPI_KEY=PASTE_YOUR_SERPAPI_KEY_HERE
# Outscraper key (https://outscraper.com) — used when REVIEWS_PROVIDER=outscraper.
OUTSCRAPER_KEY=PASTE_YOUR_OUTSCRAPER_KEY_HERE
# Safety cap on reviews fetched per place (bounds cost). Default 400.
REVIEWS_MAX=400
# A review counts as "approval" at this star rating or above. Default 4.
APPROVAL_MIN_STARS=4
# How approval is decided per review:
#   hybrid (default) — dish-sentence sentiment when clear, else the star rating
#   text             — purely what reviewers say about the DISH
#   stars            — purely the overall star rating (ignores dish text)
APPROVAL_MODE=hybrid
